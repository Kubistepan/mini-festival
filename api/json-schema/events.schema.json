{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/events.schema.json",
  "title": "EventsResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["data", "paging"],
  "properties": {
    "data": {
      "type": "array",
      "items": { "$ref": "#/$defs/Event" }
    },
    "paging": { "$ref": "#/$defs/Paging" }
  },

  "$defs": {
    "Paging": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page", "pageSize"],
      "properties": {
        "page": { "type": "integer", "minimum": 1 },
        "pageSize": { "type": "integer", "minimum": 1 }
      }
    },

    "Event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "type", "start", "end", "venueId"],
      "properties": {
        "id": { "type": "string", "pattern": "^EVT-\\d{3}$" },
        "title": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["concert", "talk", "workshop", "info"]
        },
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" },
        "venueId": { "type": "string", "pattern": "^VEN-\\d{3}$" },
        "performerId": { "type": "string", "pattern": "^PERF-\\d{3}$" }
      }
    }
  }
}